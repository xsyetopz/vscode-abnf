{
  "comments": {
    "lineComment": {
      "comment": ";"
    }
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "<",
      "close": ">"
    }
  ],
  "surroundingPairs": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "\"",
      "\""
    ],
    [
      "<",
      ">"
    ]
  ],
  "wordPattern": "[a-zA-Z][a-zA-Z0-9-]*",
  "indentationRules": {
    "increaseIndentPattern": "^[a-zA-Z][a-zA-Z0-9-]*\\s*=\\/?",
    "decreaseIndentPattern": "^\\S"
  }
}
