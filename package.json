{
  "name": "vscode-abnf-intellisense",
  "type": "module",
  "displayName": "ABNF Syntax Highlighting and Intellisense",
  "description": "ABNF (RFC 5234) grammar support with syntax highlighting, go-to definition, hover, completions, diagnostics, formatting, and more",
  "version": "0.1.2",
  "author": {
    "name": "xsyetopz"
  },
  "license": "MIT",
  "private": true,
  "publisher": "xsyetopz",
  "homepage": "https://github.com/xsyetopz/vscode-abnf-intellisense",
  "repository": {
    "type": "git",
    "url": "https://github.com/xsyetopz/vscode-abnf-intellisense.git"
  },
  "bugs": {
    "url": "https://github.com/xsyetopz/vscode-abnf-intellisense/issues"
  },
  "keywords": [
    "ABNF",
    "RFC 5234",
    "RFC 7405",
    "BNF",
    "EBNF",
    "grammar",
    "syntax",
    "syntax highlighting",
    "parser",
    "language server",
    "intellisense",
    "formatter",
    "linter",
    "diagnostics",
    "augmented backus-naur form"
  ],
  "categories": [
    "Programming Languages"
  ],
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#0d1b2a",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "abnf",
        "aliases": [
          "ABNF",
          "abnf"
        ],
        "extensions": [
          ".abnf"
        ],
        "configuration": "abnf-language-configuration.json",
        "icon": {
          "light": "logo.png",
          "dark": "logo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "abnf",
        "scopeName": "source.abnf",
        "path": "syntaxes/abnf.tmLanguage.json"
      },
      {
        "scopeName": "text.html.markdown.abnf.codeblock",
        "path": "syntaxes/abnf-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.abnf": "abnf"
        }
      }
    ],
    "snippets": [
      {
        "language": "abnf",
        "path": "snippets/abnf.json"
      }
    ],
    "configuration": {
      "title": "ABNF",
      "properties": {
        "abnf.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable diagnostics for ABNF files."
        },
        "abnf.diagnostics.unusedRules": {
          "type": "boolean",
          "default": true,
          "description": "Report rules that are defined but never referenced (as hints)."
        },
        "abnf.diagnostics.undefinedReferences": {
          "type": "boolean",
          "default": true,
          "description": "Report references to undefined rules."
        },
        "abnf.formatting.alignEquals": {
          "type": "boolean",
          "default": true,
          "description": "Align = signs across consecutive rule definitions."
        },
        "abnf.formatting.continuationIndent": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces for continuation lines."
        },
        "abnf.formatting.alternativeIndent": {
          "type": "string",
          "enum": [
            "align",
            "indent"
          ],
          "default": "align",
          "enumDescriptions": [
            "Align / under the first element after =",
            "Use fixed continuation indent"
          ],
          "description": "How to indent alternatives on continuation lines."
        },
        "abnf.formatting.blankLinesBetweenRules": {
          "type": "number",
          "default": 1,
          "description": "Number of blank lines between consecutive rule definitions."
        },
        "abnf.formatting.breakAlternatives": {
          "type": "string",
          "enum": [
            "always",
            "auto",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "Always put top-level / alternatives on their own lines",
            "Inline if it fits under maxLineLength, otherwise break",
            "Never force / alternatives onto new lines"
          ],
          "description": "How to format top-level / alternatives."
        },
        "abnf.formatting.maxLineLength": {
          "type": "number",
          "default": 80,
          "description": "Wrap long rule bodies to this many columns. Set to 0 to disable wrapping."
        },
        "abnf.formatting.preserveContinuationLineBreaks": {
          "type": "boolean",
          "default": false,
          "description": "Preserve existing continuation line breaks (newlines followed by leading whitespace) when formatting."
        },
        "abnf.formatting.spaceBeforeInlineComment": {
          "type": "number",
          "default": 2,
          "description": "Spaces before inline ; comments in rule bodies."
        },
        "abnf.formatting.insertFinalNewline": {
          "type": "boolean",
          "default": true,
          "description": "Insert a final newline at end of file."
        },
        "abnf.inlayHints.referenceCount": {
          "type": "boolean",
          "default": false,
          "description": "Show reference count after rule names."
        },
        "abnf.inlayHints.recursion": {
          "type": "boolean",
          "default": false,
          "description": "Mark directly recursive rules."
        },
        "abnf.inlayHints.unusedMarker": {
          "type": "boolean",
          "default": false,
          "description": "Mark unused rules inline (in addition to diagnostic)."
        }
      }
    }
  },
  "scripts": {
    "build": "bun build ./client/src/main.ts --outfile=./dist/extension.js --external vscode --target=node",
    "biome:check": "bunx biome check . --write --unsafe --max-diagnostics 16384",
    "biome:format": "bunx biome format . --write --max-diagnostics 16384",
    "biome:lint": "bunx biome lint . --write --max-diagnostics 16384",
    "package": "bun run build && vsce package",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@vscode/vsce-sign",
    "keytar"
  ]
}
